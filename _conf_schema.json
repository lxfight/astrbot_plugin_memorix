{
  "scope": {
    "type": "object",
    "description": "记忆作用域策略（决定不同消息在哪些范围共享记忆）",
    "items": {
      "mode": {
        "type": "string",
        "description": "作用域模式：同平台共享；同平台按用户隔离；同平台按群隔离（私聊退化到用户）；按 unified_msg_origin 最细粒度隔离",
        "default": "platform_global",
        "options": ["platform_global", "user_global", "group_global", "umo"]
      }
    }
  },
  "ingest": {
    "type": "object",
    "description": "写入策略",
    "items": {
      "record_all_events": {
        "type": "bool",
        "description": "是否记录所有消息事件",
        "default": true
      },
      "skip_empty_text": {
        "type": "bool",
        "description": "忽略空文本",
        "default": true
      }
    }
  },
  "provider": {
    "type": "object",
    "description": "AstrBot 原生模型提供商选择",
    "items": {
      "embedding_provider_id": {
        "type": "string",
        "description": "Embedding 提供商 ID（用于向量化检索）",
        "default": "",
        "_special": "select_provider",
        "obvious_hint": true
      },
      "chat_provider_id": {
        "type": "string",
        "description": "聊天提供商 ID（用于总结导入）",
        "default": "",
        "_special": "select_provider",
        "obvious_hint": true
      }
    }
  },
  "embedding": {
    "type": "object",
    "description": "向量配置（由 AstrBot Embedding Provider 执行）",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用 AstrBot Embedding Provider；关闭时使用本地确定性向量回退",
        "default": false,
        "obvious_hint": true
      },
      "dimension": {
        "type": "int",
        "description": "向量维度",
        "default": 1024
      },
      "batch_size": {
        "type": "int",
        "description": "批量大小",
        "default": 32
      },
      "max_concurrent": {
        "type": "int",
        "description": "并发请求数",
        "default": 5
      }
    }
  },
  "retrieval": {
    "type": "object",
    "description": "检索配置",
    "items": {
      "top_k_final": {
        "type": "int",
        "description": "默认返回数量",
        "default": 10
      },
      "enable_ppr": {
        "type": "bool",
        "description": "启用 PageRank 重排",
        "default": true
      },
      "enable_parallel": {
        "type": "bool",
        "description": "并行检索",
        "default": true
      },
      "temporal": {
        "type": "object",
        "description": "时序检索",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用时序检索",
            "default": true
          },
          "default_top_k": {
            "type": "int",
            "description": "时序默认 top_k",
            "default": 10
          }
        }
      }
    }
  },
  "memory": {
    "type": "object",
    "description": "记忆维护配置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用记忆维护",
        "default": true
      },
      "half_life_hours": {
        "type": "float",
        "description": "半衰期小时",
        "default": 24.0
      },
      "base_decay_interval_hours": {
        "type": "float",
        "description": "衰减周期小时",
        "default": 1.0
      },
      "prune_threshold": {
        "type": "float",
        "description": "剪枝阈值",
        "default": 0.1
      },
      "freeze_duration_hours": {
        "type": "float",
        "description": "冻结保留时长",
        "default": 24.0
      },
      "max_weight": {
        "type": "float",
        "description": "边最大权重",
        "default": 10.0
      },
      "auto_protect_ttl_hours": {
        "type": "float",
        "description": "强化自动保护时长",
        "default": 24.0
      },
      "orphan": {
        "type": "object",
        "description": "孤儿节点软删除与回收",
        "items": {
          "enable_soft_delete": {
            "type": "bool",
            "description": "启用软删除回收流程",
            "default": true
          },
          "entity_retention_days": {
            "type": "float",
            "description": "孤儿实体保留天数（超过后可标记删除）",
            "default": 7.0
          },
          "paragraph_retention_days": {
            "type": "float",
            "description": "孤儿段落保留天数（超过后可标记删除）",
            "default": 7.0
          },
          "sweep_grace_hours": {
            "type": "float",
            "description": "软删除后等待物理清理的宽限小时",
            "default": 24.0
          }
        }
      }
    }
  },
  "person_profile": {
    "type": "object",
    "description": "人物画像配置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用人物画像",
        "default": true
      },
      "opt_in_required": {
        "type": "bool",
        "description": "是否要求按会话+用户显式开启画像注入（对应 /person_profile on|off|status）",
        "default": true
      },
      "default_injection_enabled": {
        "type": "bool",
        "description": "当未设置画像开关时的默认注入状态",
        "default": false
      },
      "profile_ttl_minutes": {
        "type": "int",
        "description": "画像缓存 TTL（分钟）",
        "default": 360
      },
      "top_k_evidence": {
        "type": "int",
        "description": "画像证据数量",
        "default": 12
      }
    }
  },
  "schedule": {
    "type": "object",
    "description": "定时总结导入",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用定时总结任务",
        "default": true
      },
      "import_times": {
        "type": "list",
        "description": "每日触发时间列表，格式 HH:MM（例如 [\"04:00\", \"16:00\"]）",
        "default": ["04:00"]
      }
    }
  },
  "summarization": {
    "type": "object",
    "description": "总结配置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用总结导入",
        "default": true
      },
      "context_length": {
        "type": "int",
        "description": "总结上下文长度",
        "default": 50
      },
      "default_knowledge_type": {
        "type": "string",
        "description": "总结写入知识类型",
        "default": "narrative",
        "options": ["narrative", "factual", "mixed", "structured", "auto"]
      }
    }
  },
  "webui": {
    "type": "object",
    "description": "内嵌 WebUI",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用 WebUI",
        "default": true
      },
      "host": {
        "type": "string",
        "description": "监听地址",
        "default": "0.0.0.0"
      },
      "port": {
        "type": "int",
        "description": "监听端口",
        "default": 8092
      },
      "port_fallback_max_tries": {
        "type": "int",
        "description": "端口冲突回退尝试次数",
        "default": 20
      },
      "scope": {
        "type": "string",
        "description": "WebUI 绑定作用域。推荐 auto（跟随当前会话作用域）；也可手动指定如 aiocqhttp",
        "default": "auto"
      },
      "auth": {
        "type": "object",
        "description": "WebUI 鉴权",
        "items": {
          "enabled": {
            "type": "bool",
            "description": "启用 Bearer 鉴权",
            "default": false
          },
          "write_tokens": {
            "type": "list",
            "description": "写接口 token 列表",
            "default": []
          },
          "read_tokens": {
            "type": "list",
            "description": "读接口 token 列表",
            "default": []
          },
          "protect_read_endpoints": {
            "type": "bool",
            "description": "读接口鉴权",
            "default": false
          }
        }
      }
    }
  }
}
